{
  "name": "vip-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/frontend"
  ],
  "description": "Monorepo scaffold for the VIP task platform",
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "build:frontend": "npm run build --workspace @vip/frontend",
    "dev:api": "node scripts/kill-ports.cjs 3001 3002 3003 3004 3005 3006 && npm run build && concurrently --restart-tries 999 --restart-after 2000 --names identity,wallet,vip,tasks,notifications,admin --prefix-colors blue,green,cyan,magenta,yellow,red \"npm run start:identity\" \"npm run start:wallet\" \"npm run start:vip\" \"npm run start:tasks\" \"npm run start:notifications\" \"npm run start:admin\"",
    "dev:identity": "npm run build && node dist/apps/identity-service/src/main.js",
    "dev:wallet": "npm run build && node dist/apps/wallet-service/src/main.js",
    "dev:vip": "npm run build && node dist/apps/vip-service/src/main.js",
    "dev:tasks": "npm run build && node dist/apps/task-service/src/main.js",
    "dev:notifications": "npm run build && node dist/apps/notification-service/src/main.js",
    "dev:frontend": "npm run dev --workspace @vip/frontend",
    "start:identity": "node dist/apps/identity-service/src/main.js",
    "start:wallet": "node dist/apps/wallet-service/src/main.js",
    "start:vip": "node dist/apps/vip-service/src/main.js",
    "start:tasks": "node dist/apps/task-service/src/main.js",
    "start:notifications": "node dist/apps/notification-service/src/main.js",
    "db:create": "node scripts/create-db.cjs",
    "db:check": "node --import tsx scripts/db-check.ts",
    "migrate": "node --import tsx libs/database/src/run-migrations.ts",
    "stop:api": "node scripts/kill-ports.cjs 3001 3002 3003 3004 3005 3006",
    "dev:admin": "npm run build && node dist/apps/admin-service/src/main.js",
    "start:admin": "node dist/apps/admin-service/src/main.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.17",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.17",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.17",
    "amqplib": "^0.10.7",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.14.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.7",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.10",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.11.11",
    "concurrently": "^9.1.2",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
